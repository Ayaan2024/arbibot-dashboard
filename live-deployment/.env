BSC_WSS_URL=wss://cold-nameless-gas.bsc.quiknode.pro/ad4cb7b2db457197b3199a4048f60da95f642296
QUICKNODE_URL=https://cold-nameless-gas.bsc.quiknode.pro/ad4cb7b2db457197b3199a4048f60da95f642296
QUICKNODE_WSS=wss://cold-nameless-gas.bsc.quiknode.pro/ad4cb7b2db457197b3199a4048f60da95f642296

# ============================================
# WALLET CREDENTIALS (⚠️ KEEP SECRET)
# ============================================
PRIVATE_KEY=your_private_key_here
WALLET_ADDRESS=0xyour_wallet_address_here

# ============================================
# LIVE TRADING ACTIVATION
# ============================================
ALLOW_LIVE_TRADING=true
LIVE_EXECUTION_ENABLED=true
LIVE_TRADING_UNLOCK_CODE=I UNDERSTAND LIVE TRADING RISKS

# ============================================
# TRADE EXECUTION: BOTH MODES (Proven Strategy)
# ============================================
# This combines capital-based + flash loan trades
# Demo showed this works best - use it for live
TRADE_EXECUTION_MODE=both

# ============================================
# CAPITAL-BASED TRADES (Your Wallet USDT)
# ============================================
LIVE_TRADE_SIZE_USD=15
LIVE_MIN_PROFIT_THRESHOLD_PCT=0.85
LIVE_MIN_PROFIT_USD=0.85
LIVE_MIN_EXECUTION_GAP_PCT=0.80
LIVE_TARGET_NET_PROFIT_USD=1.25

# ============================================
# FLASH LOAN TRADES (Borrowed Capital)
# ============================================
FLASH_LOAN_THRESHOLD_PCT=0.85
FLASH_LOAN_FEE_PCT=0.09
FLASH_LOAN_MIN_AMOUNT_USD=50

# ============================================
# RISK PROTECTION
# ============================================
# Gas limits (only trade during cheap periods)
MAX_GAS_GWEI=3
GAS_SKIP_ABOVE_USD=0.10

# Slippage protection (tighter than demo for live)
LIVE_SLIPPAGE_BPS=45

# Transaction safety
LIVE_TX_DEADLINE_SECONDS=90
LIVE_RECEIPT_TIMEOUT_SECONDS=120

# ============================================
# ARM WINDOW (Security Gate)
# ============================================
# 10 minutes to confirm before live trades start
LIVE_ARM_WINDOW_SECONDS=600
LIVE_ARM_MAX_WINDOW_SECONDS=3600

# ============================================
# ENGINE SETTINGS
# ============================================
ENGINE_SCAN_INTERVAL_SECONDS=30
BNB_USDT_ESTIMATE=600
APESWAP_SCAN_PAIRS=50
