# ─── Backend (Python Flask) ───────────────────────────────────────────────────
# BSC RPC endpoints (server-side only — never expose these in the frontend)
BSC_RPC_URL=https://bsc-dataseed.binance.org/
QUICKNODE_URL=https://YOUR_QUICKNODE_BSC_ENDPOINT_HERE

# Backend API bind settings for VPS
BOT_HOST=0.0.0.0
BOT_PORT=5003

# Comma-separated frontend origins allowed to call the API
# Example: https://your-dashboard.vercel.app,https://dashboard.yourdomain.com
ALLOWED_ORIGINS=https://your-dashboard.vercel.app

# ─── Frontend (Vite / React) ──────────────────────────────────────────────────
# URL of your Flask API.
# Local dev  → leave blank or set to http://localhost:5003
# Production → set to your DigitalOcean VPS URL, e.g. http://165.232.x.x:5003
#              or your domain, e.g. https://api.lms-arb.app
VITE_API_URL=http://localhost:5003

# Set to "true" to make the dashboard default to public view mode on production
# (hides wallet controls; shows only live stats and prices)
VITE_PUBLIC_VIEW=false
